# Manimations Studio — Nginx site config
# Install:
#   sudo cp nginx.conf.example /etc/nginx/sites-available/manimations-studio
#   sudo ln -sf /etc/nginx/sites-available/manimations-studio /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Replace studio.yourdomain.com and /home/manim/manimations paths.

server {
    listen 80;
    listen [::]:80;
    server_name studio.yourdomain.com;

    # Certbot will add HTTPS redirect after: certbot --nginx -d studio.yourdomain.com

    client_max_body_size 32m;

    root /home/manim/manimations/platform/frontend/dist;
    index index.html;

    # Frontend (SPA — fallback to index.html for client routes)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API → FastAPI backend
    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Manim renders can take several minutes
        proxy_read_timeout 600s;
        proxy_connect_timeout 60s;
        proxy_send_timeout 600s;
    }

    # Long cache for static assets (Vite hashed filenames)
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }
}
